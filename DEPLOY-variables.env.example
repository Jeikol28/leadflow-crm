# ============================================================================
#  LeadFlow — Variables de entorno de PRODUCCIÓN
#  Copia estos valores en la configuración de tu hosting (NO subas este archivo
#  con los valores reales al repositorio). En .NET, el "__" (doble guion bajo)
#  representa el anidamiento del appsettings.
# ============================================================================

# ---- BACKEND (LeadFlow.Api) ----

ASPNETCORE_ENVIRONMENT=Production

# Base de datos SQL Server de producción
ConnectionStrings__DefaultConnection=Server=TU_SERVIDOR;Database=LeadFlow;User Id=TU_USUARIO;Password=TU_PASSWORD;TrustServerCertificate=True

# JWT — clave secreta de MÍNIMO 32 caracteres, distinta a la de desarrollo.
# Puedes usar esta (generada aleatoriamente) o crear otra:
JwtSettings__SecretKey=yWx3lGJnT-4B0tGf9z3xrIm_uVD1cptWYI1dHkX7gyQG8ySwcs6h1Y3_FCksEZuc
JwtSettings__Issuer=LeadFlow.Api
JwtSettings__Audience=LeadFlow.Client
JwtSettings__ExpirationMinutes=120
JwtSettings__RefreshTokenExpirationDays=7

# CORS — dominio REAL del frontend (con https, SIN localhost)
CorsSettings__AllowedOrigins__0=https://app.tudominio.com

# Hosts permitidos — dominio REAL de la API (no dejes "*")
AllowedHosts=api.tudominio.com

# Correo (Brevo SMTP)
EmailSettings__Host=smtp-relay.brevo.com
EmailSettings__Port=587
EmailSettings__UseStartTls=true
EmailSettings__SenderName=LeadFlow
EmailSettings__SenderEmail=no-reply@tudominio.com
EmailSettings__Username=TU_LOGIN_SMTP_DE_BREVO
EmailSettings__Password=xsmtpsib-TU_CLAVE_SMTP
EmailSettings__AppBaseUrl=https://app.tudominio.com

# IA (Groq)
AiSettings__Provider=Groq
AiSettings__Model=llama-3.3-70b-versatile
AiSettings__ApiKey=TU_API_KEY_DE_GROQ


# ---- FRONTEND (build) ----
# Crea un archivo  Frontend/LeadFlow.Frontend/.env.production  con:
VITE_API_URL=https://api.tudominio.com/api
